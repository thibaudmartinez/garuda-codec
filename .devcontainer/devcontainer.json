{
  "name": "Garuda dev container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--sysctl", "net.ipv6.conf.all.disable_ipv6=1",
    "--sysctl", "net.ipv6.conf.default.disable_ipv6=1"
  ],
  "postStartCommand": "/usr/local/bin/setup_veth.sh --device1 origdev --device2 destdev"
}

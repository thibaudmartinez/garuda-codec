amends "package://github.com/jdx/hk/releases/download/v1.28.0/hk@1.28.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.28.0/hk@1.28.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["mise"] = Builtins.mise
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["newlines"] = Builtins.newlines
  ["shellcheck"] = Builtins.shellcheck
  ["cargo-check"] = Builtins.cargo_check
  ["cargo-clippy"] = Builtins.cargo_clippy
  ["cargo-fmt"] = Builtins.cargo_fmt
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "none"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
